# Keep local scratch space and auxiliary worktrees out of Git in the minimal repo.
.tmp/
.worktrees/

# Ignore Python cache files created by local helper tooling.
__pycache__/
*.pyc

.env

# Local OpenTofu working directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# OpenTofu binary plans can include sensitive values and should stay local.
tfplan
tfplan-*
*.tfplan
tofuplan
tofuplan-*
*.tofuplan

.terraform.lock.hcl
.local.auto.tfvars
