$ORIGIN bohdal.name.
$TTL 300
@ IN SOA dns.bohdal.name. hostmaster.bohdal.name. (
    2026060901 ; serial
    300        ; refresh
    120        ; retry
    1209600    ; expire
    60         ; negative cache TTL
)
@      IN NS dns.bohdal.name.
dns    IN A  10.1.30.53
blocky IN A  10.1.30.53
gw     IN A  10.1.100.1
