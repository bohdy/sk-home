{
  "annotations": {
    "list": []
  },
  "description": "Cilium datapath, BGP control plane, and bounded Hubble DNS/drop/TCP telemetry.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Cilium agent and operator scrape reachability by node.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "down"
                },
                "1": {
                  "color": "green",
                  "text": "up"
                }
              },
              "type": "value"
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "up{job=~\"observability/cilium-agent|observability/cilium-operator|hubble-metrics\"}",
          "legendFormat": "{{job}} {{instance}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Cilium and Hubble targets",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "BGP session state for every Cilium node peer. Established is expected.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "cilium_bgp_control_plane_session_state",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "BGP sessions",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Cilium datapath drops by reason and direction.",
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (reason, direction) (rate(cilium_drop_count_total[5m]))",
          "legendFormat": "{{direction}} {{reason}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Datapath drops",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Hubble flow drops aggregated only by protocol and reason.",
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (protocol, reason) (rate(hubble_drop_total[5m]))",
          "legendFormat": "{{protocol}} {{reason}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Hubble drops",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "TCP flag activity aggregated without endpoint identity labels.",
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (family, flag) (rate(hubble_tcp_flags_total[5m]))",
          "legendFormat": "{{family}} {{flag}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Hubble TCP flags",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "homelab",
    "cilium",
    "hubble",
    "bgp"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Cilium and BGP",
  "uid": "sk-cilium-bgp",
  "version": 1
}
