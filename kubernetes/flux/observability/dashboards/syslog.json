{
  "annotations": {
    "list": []
  },
  "description": "TCP/UDP syslog intake, parsing, flood control, delivery, and Vector buffer health.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Events received from TCP and UDP syslog sockets.",
      "fieldConfig": {
        "defaults": {
          "unit": "eps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (component_id) (rate(vector_component_received_events_total{component_id=~\"syslog_(tcp|udp)\"}[5m]))",
          "legendFormat": "{{component_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Syslog intake",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Difference between throttle input and output reveals flood-control drops.",
      "fieldConfig": {
        "defaults": {
          "unit": "eps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (component_id) (clamp_min(rate(vector_component_received_events_total{component_id=~\"throttle_syslog_(tcp|udp)\"}[5m]) - rate(vector_component_sent_events_total{component_id=~\"throttle_syslog_(tcp|udp)\"}[5m]), 0))",
          "legendFormat": "{{component_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Flood-control drops",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Events delivered toward VictoriaLogs by source route.",
      "fieldConfig": {
        "defaults": {
          "unit": "eps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (component_id) (rate(vector_component_sent_events_total{component_id=~\"route_.*|victoria_logs\"}[5m]))",
          "legendFormat": "{{component_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Routed and delivered events",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Any Vector discard is actionable because raw input should otherwise be retained.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (component_id, host) (increase(vector_component_discarded_events_total[5m]))",
          "legendFormat": "{{host}} {{component_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Discarded events in five minutes",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "homelab",
    "syslog",
    "vector",
    "victorialogs"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Syslog",
  "uid": "sk-syslog",
  "version": 1
}
