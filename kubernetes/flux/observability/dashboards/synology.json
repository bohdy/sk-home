{
  "annotations": {
    "list": []
  },
  "description": "Synology appliance, storage, RAID, disk, and service health from the committed vendor SNMP module.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Synology system status and power status; vendor value 1 represents normal.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "normal"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "systemStatus",
          "legendFormat": "{{instance}} system",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "powerStatus",
          "legendFormat": "{{instance}} power",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "System health",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "System and disk temperature telemetry in degrees Celsius.",
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "temperature",
          "legendFormat": "{{instance}} system",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "diskTemperature",
          "legendFormat": "{{instance}} {{diskID}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Temperatures",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Current vendor RAID and disk status values for operator investigation.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "raidStatus",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "diskStatus",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "RAID and disk status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Storage device reads and writes from Synology SPACEIO/STORAGEIO counters.",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "rate(storageIONReadX[5m])",
          "legendFormat": "{{storageIODevice}} read",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "rate(storageIONWrittenX[5m])",
          "legendFormat": "{{storageIODevice}} write",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Storage I/O",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 42,
  "tags": [
    "homelab",
    "synology",
    "storage",
    "snmp"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Synology",
  "uid": "sk-synology",
  "version": 1
}
