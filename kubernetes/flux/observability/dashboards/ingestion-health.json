{
  "annotations": {
    "list": []
  },
  "description": "End-to-end metrics and log ingestion throughput, drops, buffers, storage, and scrape health.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "VictoriaMetrics rows accepted and rejected by ingestion protocol.",
      "fieldConfig": {
        "defaults": {
          "unit": "rows/s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (type) (rate(vm_rows_inserted_total[5m]))",
          "legendFormat": "inserted {{type}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (reason) (rate(vm_rows_ignored_total[5m]))",
          "legendFormat": "ignored {{reason}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Metrics ingestion",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "VictoriaLogs accepted and dropped rows.",
      "fieldConfig": {
        "defaults": {
          "unit": "rows/s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(vl_rows_ingested_total[5m]))",
          "legendFormat": "ingested",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(vl_rows_dropped_total[5m]))",
          "legendFormat": "dropped",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Log ingestion",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Vector's persistent VictoriaLogs buffers by node.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * vector_buffer_size_bytes{buffer_id=\"victoria_logs\"} / vector_buffer_max_size_bytes{buffer_id=\"victoria_logs\"}",
          "legendFormat": "{{host}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Vector buffer utilization",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Current number of failing scrape targets by job.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (job) (up == 0)",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Failed scrape targets",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "homelab",
    "ingestion",
    "victoriametrics",
    "victorialogs",
    "vector"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Ingestion Health",
  "uid": "sk-ingestion",
  "version": 1
}
