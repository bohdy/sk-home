{
  "annotations": {
    "list": []
  },
  "description": "Read-only Proxmox cluster, node, guest, storage, and backup coverage from Prometheus PVE Exporter.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Online state for Proxmox nodes, QEMU guests, containers, and storage objects.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "down"
                },
                "1": {
                  "color": "green",
                  "text": "up"
                }
              },
              "type": "value"
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "pve_up",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Object status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true
            },
            "renameByName": {
              "Value": "state"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Memory consumption for nodes and guests.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "pve_memory_usage_bytes",
          "legendFormat": "{{id}} used",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "pve_memory_size_bytes",
          "legendFormat": "{{id}} total",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Memory",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Storage capacity and utilization for Proxmox objects.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "pve_disk_usage_bytes",
          "legendFormat": "{{id}} used",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "pve_disk_size_bytes",
          "legendFormat": "{{id}} total",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Disk and storage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Guests not covered by a configured Proxmox backup job.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "pve_not_backed_up_total",
          "legendFormat": "{{id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Guests without backup coverage",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "homelab",
    "proxmox",
    "virtualization"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Proxmox",
  "uid": "sk-proxmox",
  "version": 1
}
