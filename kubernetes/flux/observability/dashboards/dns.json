{
  "annotations": {
    "list": []
  },
  "description": "Blocky client-facing DNS health and CoreDNS authoritative/recursive behavior.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "DNS query rate by Blocky response type.",
      "fieldConfig": {
        "defaults": {
          "unit": "qps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (response_type) (rate(blocky_query_total[5m]))",
          "legendFormat": "{{response_type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Blocky query rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Blocky response latency at operator-relevant percentiles.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(blocky_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(blocky_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Blocky response latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Blocky cache effectiveness derived from hit and miss counters.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(blocky_cache_hits_total[5m])) / clamp_min(sum(rate(blocky_cache_hits_total[5m]) + rate(blocky_cache_misses_total[5m])), 1)",
          "legendFormat": "hit ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Blocky cache hit ratio",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "CoreDNS request volume by server, zone, protocol, and family.",
      "fieldConfig": {
        "defaults": {
          "unit": "qps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (server, zone, proto, family) (rate(coredns_dns_requests_total[5m]))",
          "legendFormat": "{{zone}} {{proto}}/{{family}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "CoreDNS request rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "homelab",
    "dns",
    "blocky",
    "coredns"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "DNS",
  "uid": "sk-dns",
  "version": 1
}
