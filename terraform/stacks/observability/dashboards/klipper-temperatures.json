{
  "title": "Klipper Temperatures",
  "tags": ["klipper", "monitoring", "temperatures"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Nozzles, Bed, and Chassis Temperatures",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "Nozzle 1",
          "expr": "(max(klipper_temperature_sensor_temperature{sensor=~\"(?i)(nozzle[_ -]?1|tool[_ -]?0|extruder[_ -]?0|e0)\"}) or max(klipper_generic_heater_temperature{heater=~\"(?i)(nozzle[_ -]?1|tool[_ -]?0|extruder[_ -]?0|e0)\"}) or max(klipper_extruder_temperature))"
        },
        {
          "refId": "B",
          "legendFormat": "Nozzle 2",
          "expr": "(max(klipper_temperature_sensor_temperature{sensor=~\"(?i)(nozzle[_ -]?2|tool[_ -]?1|extruder[_ -]?1|e1)\"}) or max(klipper_generic_heater_temperature{heater=~\"(?i)(nozzle[_ -]?2|tool[_ -]?1|extruder[_ -]?1|e1)\"}))"
        },
        {
          "refId": "C",
          "legendFormat": "Nozzle 3",
          "expr": "(max(klipper_temperature_sensor_temperature{sensor=~\"(?i)(nozzle[_ -]?3|tool[_ -]?2|extruder[_ -]?2|e2)\"}) or max(klipper_generic_heater_temperature{heater=~\"(?i)(nozzle[_ -]?3|tool[_ -]?2|extruder[_ -]?2|e2)\"}))"
        },
        {
          "refId": "D",
          "legendFormat": "Nozzle 4",
          "expr": "(max(klipper_temperature_sensor_temperature{sensor=~\"(?i)(nozzle[_ -]?4|tool[_ -]?3|extruder[_ -]?3|e3)\"}) or max(klipper_generic_heater_temperature{heater=~\"(?i)(nozzle[_ -]?4|tool[_ -]?3|extruder[_ -]?3|e3)\"}))"
        },
        {
          "refId": "E",
          "legendFormat": "Heatbed",
          "expr": "(max(klipper_heater_bed_temperature) or max(klipper_temperature_sensor_temperature{sensor=~\"(?i).*bed.*\"}) or max(klipper_generic_heater_temperature{heater=~\"(?i).*bed.*\"}))"
        },
        {
          "refId": "F",
          "legendFormat": "Chassis",
          "expr": "(max(klipper_temperature_sensor_temperature{sensor=~\"(?i).*(chassis|cavity).*\"}) or max(klipper_generic_heater_temperature{heater=~\"(?i).*(chassis|cavity).*\"}))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 350
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 2,
