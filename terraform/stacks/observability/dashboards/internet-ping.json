{
  "title": "Internet Ping Monitoring",
  "tags": ["network", "ping", "blackbox"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "geomap",
      "title": "Ping Targets Map",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{job=\"ping\",latitude!=\"\"}",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "view": {
          "id": "coords",
          "lat": 51,
          "lon": 10,
          "zoom": 4
        },
        "basemap": {
          "type": "default",
          "name": "Basemap"
        },
        "layers": [
          {
            "type": "markers",
            "name": "Ping Status",
            "config": {
              "showLegend": true,
              "style": {
                "size": {
                  "fixed": 10
                },
                "color": {
                  "field": "Value",
                  "fixed": "dark-green"
                },
                "symbol": {
                  "fixed": "img/icons/marker/circle.svg"
                }
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "latitude",
              "longitude": "longitude"
            }
          }
        ],
        "tooltip": {
          "mode": "details"
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "dark-green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "dark-red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-red", "value": null },
              { "color": "dark-green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Availability (5m avg)",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(probe_success{job=\"ping\"}[5m]) * 100",
          "legendFormat": "{{location}} ({{instance}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-red", "value": null },
              { "color": "dark-orange", "value": 90 },
              { "color": "dark-yellow", "value": 99 },
              { "color": "dark-green", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Current Latency",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_duration_seconds{job=\"ping\"}",
          "legendFormat": "{{location}} ({{instance}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-green", "value": null },
              { "color": "dark-yellow", "value": 0.05 },
              { "color": "dark-orange", "value": 0.1 },
              { "color": "dark-red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_duration_seconds{job=\"ping\"}",
          "legendFormat": "{{location}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Packet Loss Over Time (5m avg)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - avg_over_time(probe_success{job=\"ping\"}[5m])) * 100",
          "legendFormat": "{{location}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-green", "value": null },
              { "color": "dark-yellow", "value": 1 },
              { "color": "dark-orange", "value": 5 },
              { "color": "dark-red", "value": 10 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "ICMP Phase Duration",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_icmp_duration_seconds{job=\"ping\"}",
          "legendFormat": "{{location}} - {{phase}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
