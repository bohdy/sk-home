# Set the project identifier for this repository's infrastructure stack.
project_name = "sk-home"

# Choose the target environment for local planning or future deployments.
environment = "home"

# Identify the primary access domain for edge identity configuration.
access_domain = "bohdal.name"

# Point the stack at the public Cloudflare zone used for the live hostnames.
cloudflare_zone_id = "replace-me"

# Provide the kubeconfig path materialized by the shared Bitwarden helper.
kubeconfig_path = ".tmp/terraform-runtime/kubeconfig/config"

# Preserve the existing tunnel secret from the Pulumi state export before import.
tunnel_secret_b64 = "replace-me"

# Add optional non-sensitive metadata tags as needed.
additional_tags = {
  owner = "home-lab"
}
