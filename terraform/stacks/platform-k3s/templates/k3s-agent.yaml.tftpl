variant: flatcar
version: 1.0.0

passwd:
  users:
    - name: core
      ssh_authorized_keys:
        - ${ssh_public_key}

storage:
  files:
    # Set the hostname for this node.
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: ${hostname}

    # Static network configuration required very early in boot.
    - path: /etc/systemd/network/10-eth0.network
      mode: 0644
      contents:
        inline: |
          [Match]
          Name=e*

          [Network]
          Address=${node_ip}/${prefix_length}
          Gateway=${gateway}
          DNS=${dns_servers}

    # k3s agent runtime configuration.
    - path: /etc/rancher/k3s/config.yaml
      mode: 0644
      contents:
        inline: |
          server: "https://${server_ip}:6443"
          token: "${k3s_token}"
          node-ip: "${node_ip}"

    # Install script that fetches the requested k3s release at runtime.
    - path: /opt/sk-home/install-k3s.sh
      mode: 0755
      contents:
        inline: |
          #!/usr/bin/env bash
          set -euo pipefail

          VERSION="${k3s_version}"
          BIN_DIR="/opt/bin"
          BIN_PATH="$${BIN_DIR}/k3s"
          URL="https://github.com/k3s-io/k3s/releases/download/${k3s_version}/k3s"

          mkdir -p "$${BIN_DIR}"

          if [[ -x "$${BIN_PATH}" ]] && "$${BIN_PATH}" --version 2>/dev/null | grep -q "$${VERSION}"; then
            exit 0
          fi

          curl --fail --location --silent --show-error "$${URL}" --output "$${BIN_PATH}"
          chmod 0755 "$${BIN_PATH}"

systemd:
  units:
    # Disable locksmithd in favour of explicit reboot coordination.
    - name: locksmithd.service
      mask: true

    # Install (or refresh) k3s before the agent service starts.
    - name: k3s-install.service
      enabled: true
      contents: |
        [Unit]
        Description=Install k3s binary
        Wants=network-online.target
        After=network-online.target

        [Service]
        Type=oneshot
        ExecStart=/opt/sk-home/install-k3s.sh
        RemainAfterExit=yes

        [Install]
        WantedBy=multi-user.target

    # Start k3s in agent mode after binary install and network are ready.
    - name: k3s-agent.service
      enabled: true
      contents: |
        [Unit]
        Description=k3s agent
        Documentation=https://k3s.io
        Wants=network-online.target
        After=network-online.target k3s-install.service
        Requires=k3s-install.service

        [Service]
        Type=exec
        KillMode=process
        Delegate=yes
        LimitNOFILE=1048576
        LimitNPROC=infinity
        LimitCORE=infinity
        TasksMax=infinity
        TimeoutStartSec=0
        Restart=always
        RestartSec=5s
        ExecStartPre=-/sbin/modprobe br_netfilter
        ExecStartPre=-/sbin/modprobe overlay
        ExecStart=/opt/bin/k3s agent --config /etc/rancher/k3s/config.yaml

        [Install]
        WantedBy=multi-user.target
