# Cloudflare R2 access key used by the Terraform S3 backend for remote state.
AWS_ACCESS_KEY_ID=""

# Cloudflare R2 secret access key used by the Terraform S3 backend.
AWS_SECRET_ACCESS_KEY=""

# Cloudflare R2 region value required by the S3 backend compatibility layer.
AWS_REGION="auto"

# Cloudflare account ID used to construct the R2 S3 endpoint URL.
CLOUDFLARE_ACCOUNT_ID="3b4089f3bd57e01c9d7c03c2587c3436"

# Cloudflare R2 bucket that stores all Terraform state files for this repo.
TFSTATE_BUCKET="sk-home"

# MikroTik automation username used by the RouterOS Terraform provider.
TF_VAR_mikrotik_username="terraform"

# MikroTik automation password used by the RouterOS Terraform provider.
TF_VAR_mikrotik_password=""

# Set to true only while using self-signed MikroTik certificates during setup.
TF_VAR_mikrotik_insecure="true"

# Root project identifier shared by Terraform stacks in this repository.
TF_VAR_project_name="sk-home"

# Default deployment environment name for local Terraform runs.
TF_VAR_environment="home"

# Default logical site name for physical-network stacks.
TF_VAR_site_name="primary"
